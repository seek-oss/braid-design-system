#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.mjs" "$@"
fi
# cmd-shim-target=/Users/cpaulsen/Code/braid-design-system/.pnpm-store/v11/links/@/pnpm/11.3.0/77820c72d91c6a00d6736a1694e27af3eb747a6733e77e9ab25da3410d8b087a/node_modules/pnpm/bin/pnpm.mjs
